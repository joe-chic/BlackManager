<?xml version="1.0" encoding="utf-8"?>
<!-- item_task.xml -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:background="#1E1E1E"
    app:strokeColor="#333333"
    app:strokeWidth="1dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:divider="?android:attr/dividerVertical"
            android:showDividers="middle">

            <!-- Title -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Título"
                app:boxStrokeColor="#FFFFFF"
                app:hintTextColor="@android:color/white">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Description -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Descripción"
                app:boxStrokeColor="#FFFFFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="2"
                    android:gravity="top"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Assignees Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Asignados"
                app:boxStrokeColor="#FFFFFF">

                <AutoCompleteTextView
                    android:id="@+id/actvAssignees"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:focusableInTouchMode="true"
                    android:imeOptions="actionDone"
                    android:clickable="true"
                    android:dropDownWidth="match_parent"
                    android:popupBackground="#1E1E1E"
                    android:textColor="#000000"
                    android:textColorHint="#AAAAAA"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Assignees Chips -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupAssignees"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp"/>

            <!-- Kick-off Date -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fecha de inicio"
                app:boxStrokeColor="#FFFFFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStartDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:textColor="#000000"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Deadline -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fecha límite"
                app:boxStrokeColor="#FFFFFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDeadline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="true"
                    android:clickable="true"
                    android:textColor="#000000"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Priority Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Prioridad"
                app:boxStrokeColor="#FFFFFF">

                <AutoCompleteTextView
                    android:id="@+id/actvPriority"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:focusable="true"
                    android:clickable="true"
                    android:dropDownWidth="match_parent"
                    android:popupBackground="#1E1E1E"
                    android:textColor="#000000"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Status Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Estado"
                app:boxStrokeColor="#FFFFFF">

                <AutoCompleteTextView
                    android:id="@+id/actvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:focusable="true"
                    android:clickable="true"
                    android:dropDownWidth="match_parent"
                    android:popupBackground="#1E1E1E"
                    android:textColor="#000000"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Creator -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Creador"
                app:boxStrokeColor="#888888">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCreator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:enabled="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tags Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Etiquetas"
                app:boxStrokeColor="#FFFFFF">

                <AutoCompleteTextView
                    android:id="@+id/actvTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:imeOptions="actionDone"
                    android:clickable="true"
                    android:dropDownWidth="match_parent"
                    android:popupBackground="#1E1E1E"
                    android:textColor="#000000"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tags Chips -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacing="8dp"/>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btnDelete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Eliminar"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@android:color/holo_red_dark"/>

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guardar"
                    android:layout_marginStart="8dp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="?attr/colorPrimary"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</com.google.android.material.card.MaterialCardView>
