<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_task.xml -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E0E0E"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Section title above form -->
        <TextView
            android:id="@+id/tvCreateTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crear nueva tarea"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"/>

        <!-- include your form here -->
        <include
            layout="@layout/item_task_form"
            android:id="@+id/cardTaskInputRoot"/>

        <!-- Section title above task list -->
        <TextView
            android:id="@+id/tvTasksTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tareas"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"/>

        <!-- RecyclerView for saved tasks -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/cardTaskInputRoot"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:clipToPadding="false"
            android:padding="8dp"
            android:scrollbars="vertical"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>